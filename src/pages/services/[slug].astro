---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import PageLayout from '@/layouts/PageLayout.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import CTABand from '@/components/CTABand.astro';
import DottedDivider from '@/components/DottedDivider.astro';
import Icon from '@/components/Icon.astro';
import { site } from '@/config/site';
import { serviceSchema } from '@/lib/schema';

export const getStaticPaths = (async () => {
  const services = await getCollection('services');
  return services.map((s) => ({ params: { slug: s.id }, props: { service: s } }));
}) satisfies GetStaticPaths;

const { service } = Astro.props;
const d = service.data;
const url = `${site.url}/services/${service.id}`;

const all = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);
const related = all.filter((s) => s.id !== service.id).slice(0, 3);

const columns = [
  { icon: 'check', title: 'What’s included', items: d.includes },
  { icon: 'users', title: 'Who it helps', items: d.helps },
  { icon: 'heart', title: 'What to expect', items: d.expect },
] as const;
---
<PageLayout
  title={`${d.title} | In-Home Care`}
  description={d.metaDescription}
  eyebrow="Our Services"
  heading={d.title}
  intro={d.summary}
  crumbs={[
    { name: 'Services', href: '/services' },
    { name: d.shortTitle ?? d.title, href: `/services/${service.id}` },
  ]}
  jsonLd={[serviceSchema({ name: d.title, description: d.metaDescription, url })]}
>
  <section class="container-prose py-14 md:py-20">
    <div class="grid gap-12 lg:grid-cols-[1fr_320px] lg:gap-16">
      <div>
        <DottedDivider align="left" />
        <p class="mt-6 max-w-2xl text-xl leading-relaxed text-ink">{d.intro}</p>

        <div class="mt-12 space-y-10">
          {columns.map((col) => (
            <div>
              <h2 class="flex items-center gap-3 text-2xl text-sage-900">
                <Icon name={col.icon} size={24} class="text-sage-600" />
                {col.title}
              </h2>
              <ul class="mt-5 grid gap-3 sm:grid-cols-2">
                {col.items.map((item) => (
                  <li class="flex items-start gap-3 rounded-2xl border border-sage-100 bg-white p-4 shadow-soft">
                    <Icon name="check" size={20} class="mt-0.5 shrink-0 text-teal-600" />
                    <span class="text-ink-soft">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- sticky aside CTA -->
      <aside class="lg:sticky lg:top-28 lg:self-start">
        <div class="rounded-3xl border border-sage-100 bg-sage-50/70 p-7 shadow-soft">
          <h2 class="text-xl text-sage-900">Is this care right for your family?</h2>
          <p class="mt-3 text-ink-soft">
            Let’s talk it through. Your in-home assessment is free, and there’s
            never any pressure.
          </p>
          <a href="/contact" class="mt-5 inline-flex min-h-[48px] w-full items-center justify-center gap-2 rounded-xl bg-gold-500 px-5 font-semibold text-ink shadow-soft transition-colors hover:bg-gold-400">
            <Icon name="heart" size={20} /> Request a Free Assessment
          </a>
          <a href={site.phoneHref} class="mt-3 inline-flex min-h-[48px] w-full items-center justify-center gap-2 rounded-xl border-2 border-sage-600 px-5 font-semibold text-sage-800 transition-colors hover:bg-sage-600 hover:text-cream">
            <Icon name="phone" size={20} /> {site.phone}
          </a>
        </div>
      </aside>
    </div>
  </section>

  <!-- related services -->
  <section class="wash-sage grain relative py-14 md:py-20">
    <div class="container-prose">
      <h2 class="text-2xl text-sage-900 sm:text-3xl">Explore more of our care</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {related.map((s) => (
          <ServiceCard
            href={`/services/${s.id}`}
            title={s.data.shortTitle ?? s.data.title}
            summary={s.data.summary}
          />
        ))}
      </div>
    </div>
  </section>

  <CTABand />
</PageLayout>
