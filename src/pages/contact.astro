---
import PageLayout from '@/layouts/PageLayout.astro';
import ContactForm from '@/components/ContactForm.astro';
import MapEmbed from '@/components/MapEmbed.astro';
import Icon from '@/components/Icon.astro';
import { site } from '@/config/site';

const cityLine = [site.address.city, site.address.region]
  .filter(Boolean)
  .join(', ');
---
<PageLayout
  title="Contact Us"
  description={`Contact Twinkling Hearts In Home Care to request a free in-home assessment. Call ${site.phone} or send a message — we respond within one business day.`}
  eyebrow="Let’s Talk"
  heading="Request your free in-home assessment"
  intro="Reaching out is the first step toward peace of mind. Tell us about your loved one and we’ll help you find the right care — no cost, no obligation."
  crumbs={[{ name: 'Contact', href: '/contact' }]}
>
  <section class="container-prose py-14 md:py-20">
    <div class="grid gap-10 lg:grid-cols-[1fr_360px] lg:gap-14">
      <div>
        <ContactForm />
      </div>

      <aside class="space-y-6">
        <div class="rounded-3xl border border-sage-100 bg-sage-50/70 p-7 shadow-soft">
          <h2 class="text-xl text-sage-900">Prefer to call?</h2>
          <p class="mt-2 text-ink-soft">Many families do. We’d love to hear from you.</p>
          <a href={site.phoneHref} class="mt-4 flex items-center gap-3 text-lg font-semibold text-teal-700 hover:text-teal-600">
            <Icon name="phone" size={22} /> {site.phone}
          </a>
          <a href={`mailto:${site.email}`} class="mt-3 flex items-center gap-3 font-semibold text-teal-700 hover:text-teal-600">
            <Icon name="mail" size={22} /> {site.email}
          </a>
        </div>

        <div class="rounded-3xl border border-sage-100 bg-white p-7 shadow-soft">
          <ul class="space-y-4 text-ink-soft">
            <li class="flex items-start gap-3">
              <Icon name="clock" size={22} class="mt-0.5 shrink-0 text-sage-600" />
              <span><span class="block font-semibold text-sage-900">Hours</span>{site.hours.display}<br /><span class="text-sm text-taupe-600">{site.hours.office}</span></span>
            </li>
            {cityLine && (
              <li class="flex items-start gap-3">
                <Icon name="pin" size={22} class="mt-0.5 shrink-0 text-sage-600" />
                <span><span class="block font-semibold text-sage-900">Serving</span>{site.serviceArea}</span>
              </li>
            )}
            <li class="flex items-start gap-3">
              <Icon name="heart" size={22} class="mt-0.5 shrink-0 text-sage-600" />
              <span><span class="block font-semibold text-sage-900">Response time</span>We reply within one business day.</span>
            </li>
          </ul>
        </div>

        <MapEmbed class="min-h-[240px]" />

        <p class="rounded-2xl bg-gold-200/40 p-4 text-center text-sm font-semibold text-ink">
          In a medical emergency, always call 911.
        </p>
      </aside>
    </div>
  </section>
</PageLayout>
