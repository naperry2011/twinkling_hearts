---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import PageLayout from '@/layouts/PageLayout.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import MapEmbed from '@/components/MapEmbed.astro';
import CTABand from '@/components/CTABand.astro';
import Icon from '@/components/Icon.astro';
import { site } from '@/config/site';
import { serviceSchema } from '@/lib/schema';

export const getStaticPaths = (async () => {
  const areas = await getCollection('areas');
  return areas.map((a) => ({ params: { slug: a.id }, props: { area: a } }));
}) satisfies GetStaticPaths;

const { area } = Astro.props;
const d = area.data;
const url = `${site.url}/service-areas/${area.id}`;
const cityRegion = `${d.city}, ${d.region}`;

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);

const trust = [
  { icon: 'shield', label: 'Insured & bonded for your protection' },
  { icon: 'check', label: 'Background-checked, trained caregivers' },
  { icon: 'home', label: 'Locally owned & family-run' },
  { icon: 'heart', label: 'Free, no-obligation in-home assessment' },
] as const;
---
<PageLayout
  title={`In-Home Senior Care in ${cityRegion}`}
  description={d.metaDescription}
  eyebrow="Service Area"
  heading={`In-Home Senior Care in ${d.city}, ${d.regionName}`}
  intro={d.intro}
  crumbs={[
    { name: 'Service Areas', href: '/service-areas' },
    { name: cityRegion, href: `/service-areas/${area.id}` },
  ]}
  jsonLd={[serviceSchema({
    name: `In-Home Senior Care in ${cityRegion}`,
    description: d.metaDescription,
    url,
  })]}
>
  <section class="container-prose py-14 md:py-20">
    <div class="grid gap-12 lg:grid-cols-[1fr_340px] lg:gap-16">
      <div>
        <h2 class="text-2xl text-sage-900 sm:text-3xl">Care available in {d.city}</h2>
        <p class="mt-4 max-w-2xl text-lg text-ink-soft">
          Our full range of compassionate, non-medical home care is available to
          families throughout {d.city} and the surrounding area:
        </p>
        <div class="mt-8 grid gap-6 sm:grid-cols-2">
          {services.map((s) => (
            <ServiceCard
              href={`/services/${s.id}`}
              icon={s.data.icon}
              title={s.data.shortTitle ?? s.data.title}
              summary={s.data.summary}
            />
          ))}
        </div>

        {d.neighborhoods.length > 0 && (
          <div class="mt-10">
            <h3 class="text-xl text-sage-900">Neighborhoods we serve</h3>
            <ul class="mt-4 flex flex-wrap gap-2">
              {d.neighborhoods.map((n) => (
                <li class="rounded-full bg-sage-50 px-4 py-1.5 text-sm font-semibold text-sage-800">{n}</li>
              ))}
            </ul>
          </div>
        )}

        <ul class="mt-10 grid gap-3 sm:grid-cols-2">
          {trust.map((t) => (
            <li class="flex items-center gap-3 text-sage-800">
              <Icon name={t.icon} size={22} class="shrink-0 text-sage-600" />
              <span class="font-medium">{t.label}</span>
            </li>
          ))}
        </ul>
      </div>

      <aside class="space-y-6 lg:sticky lg:top-28 lg:self-start">
        <div class="rounded-3xl border border-sage-100 bg-sage-50/70 p-7 shadow-soft">
          <h2 class="text-xl text-sage-900">Caring for {d.city} families</h2>
          <p class="mt-3 text-ink-soft">Reach out today for a free in-home assessment.</p>
          <a href="/contact" class="mt-5 inline-flex min-h-[48px] w-full items-center justify-center gap-2 rounded-xl bg-gold-500 px-5 font-semibold text-ink shadow-soft transition-colors hover:bg-gold-400">
            <Icon name="heart" size={20} /> Free Assessment
          </a>
          <a href={site.phoneHref} class="mt-3 inline-flex min-h-[48px] w-full items-center justify-center gap-2 rounded-xl border-2 border-sage-600 px-5 font-semibold text-sage-800 transition-colors hover:bg-sage-600 hover:text-cream">
            <Icon name="phone" size={20} /> {site.phone}
          </a>
        </div>
        <MapEmbed title={`Map of ${cityRegion}`} class="min-h-[260px]" />
      </aside>
    </div>
  </section>
  <CTABand />
</PageLayout>
