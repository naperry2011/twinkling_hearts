---
import Icon from './Icon.astro';
interface Props {
  quote: string;
  /** Accepted for callers but not displayed (we show relation + location). */
  author?: string;
  relation: string;
  location?: string;
}
const { quote, relation, location } = Astro.props;
---
<figure class="flex h-full flex-col rounded-3xl border border-sage-100 bg-white p-7 shadow-soft">
  <div class="flex gap-1 text-gold-500" aria-hidden="true">
    {Array.from({ length: 5 }).map(() => <Icon name="star" size={18} />)}
  </div>
  <blockquote class="mt-4 flex-1 text-[1.1rem] leading-relaxed text-ink">
    <p>“{quote}”</p>
  </blockquote>
  <figcaption class="mt-5 border-t border-sage-100 pt-4 text-sm">
    <span class="font-semibold text-sage-900">{relation}</span>
    {location && <span class="text-taupe-600"> · {location}</span>}
  </figcaption>
</figure>
