---
/** Gold dotted/flourish divider echoing the logo's underline + heart dots. */
import Icon from './Icon.astro';
interface Props {
  class?: string;
  align?: 'center' | 'left';
}
const { class: className = '', align = 'center' } = Astro.props;
---
<div
  aria-hidden="true"
  class:list={[
    'flex items-center gap-3 text-gold-500',
    align === 'center' ? 'justify-center' : 'justify-start',
    className,
  ]}
>
  <span class="h-px w-10 bg-gradient-to-r from-transparent to-gold-400"></span>
  <span class="flex items-center gap-1.5">
    <span class="h-1 w-1 rounded-full bg-gold-400/70"></span>
    <span class="h-1.5 w-1.5 rounded-full bg-gold-500"></span>
    <Icon name="heart" size={14} class="text-gold-500" />
    <span class="h-1.5 w-1.5 rounded-full bg-gold-500"></span>
    <span class="h-1 w-1 rounded-full bg-gold-400/70"></span>
  </span>
  <span class="h-px w-10 bg-gradient-to-l from-transparent to-gold-400"></span>
</div>
