---
import Button from './Button.astro';
import Sparkle from './Sparkle.astro';
import LeafSprig from './LeafSprig.astro';
import DottedDivider from './DottedDivider.astro';
import { site } from '@/config/site';
interface Props {
  title?: string;
  text?: string;
}
const {
  title = "Ready to talk? Your first conversation is free.",
  text = "Tell us about your loved one and we'll help you find the right care — with no cost and no obligation.",
} = Astro.props;
---
<section class="grain relative overflow-hidden border-y border-gold-300/60 bg-gradient-to-br from-[#f7eed7] via-cream to-sage-50">
  <!-- decorative twinkles + botanicals -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0">
    <Sparkle size={96} trail class="absolute right-8 top-8 text-gold-400/60" />
    <Sparkle size={40} class="absolute bottom-10 left-12 text-teal-400/40" />
    <LeafSprig size={120} class="absolute -bottom-3 -left-4 text-sage-300/60" />
    <LeafSprig size={110} flip class="absolute -top-2 right-2 text-sage-300/50" />
  </div>
  <div class="container-prose relative flex flex-col items-center gap-5 py-16 text-center md:py-20">
    <h2 class="max-w-2xl text-3xl text-sage-900 sm:text-4xl">{title}</h2>
    <DottedDivider />
    <p class="max-w-xl text-lg text-ink-soft">{text}</p>
    <div class="mt-2 flex flex-col gap-3 sm:flex-row">
      <Button href="/contact" variant="foil" size="lg" icon="heart">Request a Free Assessment</Button>
      <Button href={site.phoneHref} variant="outline" size="lg" icon="phone">
        Call {site.phone}
      </Button>
    </div>
  </div>
</section>
