---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import logoLockup from '@/assets/images/logo-lockup.png';
import { site, navLinks, socialLinks } from '@/config/site';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---
<header class="sticky top-0 z-40">
  <!-- Utility strip -->
  <div class="bg-sage-800 text-white">
    <div class="container-prose flex items-center justify-between gap-4 py-2 text-sm">
      <span class="hidden items-center gap-2 text-sage-100 sm:inline-flex">
        <Icon name="clock" size={15} class="text-gold-300" />
        {site.hours.display}
      </span>
      <span class="flex items-center gap-5">
        <a href={site.phoneHref} class="inline-flex items-center gap-2 font-semibold text-white hover:text-gold-300">
          <Icon name="phone" size={15} class="text-gold-300" />
          {site.phone}
        </a>
        <span class="hidden items-center gap-3 md:inline-flex">
          {socialLinks.map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="text-white hover:text-gold-300">
              <Icon name={s.key} size={16} />
            </a>
          ))}
        </span>
      </span>
    </div>
  </div>

  <!-- Main bar -->
  <div class="border-b border-sage-100 bg-cream/90 backdrop-blur-md">
    <div class="container-prose flex items-center justify-between gap-4 py-2.5">
      <a href="/" class="flex items-center rounded-lg" aria-label={`${site.name} — home`}>
        <Image
          src={logoLockup}
          alt={site.name}
          widths={[180, 260, 360]}
          sizes="(min-width: 640px) 130px, 108px"
          class="h-16 w-auto sm:h-[4.5rem]"
          loading="eager"
          fetchpriority="high"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
        {navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? 'page' : undefined}
            class:list={[
              'group relative px-3 py-2 text-[0.8rem] font-semibold uppercase tracking-[0.12em] transition-colors',
              isActive(link.href) ? 'text-sage-900' : 'text-ink-soft hover:text-sage-800',
            ]}
          >
            {link.label}
            <span
              aria-hidden="true"
              class:list={[
                'absolute inset-x-2 -bottom-0.5 h-0.5 rounded-full bg-gradient-to-r from-gold-300 to-gold-500 transition-transform duration-300 origin-center',
                isActive(link.href) ? 'scale-x-100' : 'scale-x-0 group-hover:scale-x-100',
              ]}
            ></span>
          </a>
        ))}
      </nav>

      <div class="hidden lg:block">
        <a
          href="/contact"
          class="bg-foil inline-flex min-h-[46px] items-center gap-2 rounded-full px-5 font-semibold text-ink shadow-soft transition-all hover:-translate-y-0.5 hover:shadow-lift"
        >
          <Icon name="heart" size={18} />
          Free Assessment
        </a>
      </div>

      <!-- Mobile toggle -->
      <button
        type="button"
        id="menu-toggle"
        class="inline-flex h-11 w-11 items-center justify-center rounded-lg text-sage-900 hover:bg-sage-100 lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <Icon name="menu" size={28} />
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" hidden class="border-t border-sage-100 bg-cream lg:hidden">
      <nav class="container-prose flex flex-col gap-1 py-4" aria-label="Mobile">
        {navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? 'page' : undefined}
            class:list={[
              'rounded-lg px-3 py-3 text-lg font-semibold',
              isActive(link.href) ? 'bg-sage-100 text-sage-900' : 'text-ink-soft hover:bg-sage-50',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/contact"
          class="bg-foil mt-3 inline-flex min-h-[52px] items-center justify-center gap-2 rounded-full px-5 font-semibold text-ink shadow-soft"
        >
          <Icon name="heart" size={20} /> Request a Free Assessment
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      toggle.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
      menu.hidden = open;
    });
  }
</script>
