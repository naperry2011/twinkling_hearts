---
import Icon from './Icon.astro';
interface Props {
  href: string;
  icon: 'hands' | 'pill' | 'broom' | 'respite';
  title: string;
  summary: string;
}
const { href, icon, title, summary } = Astro.props;
---
<a
  href={href}
  class="group flex h-full flex-col rounded-3xl border border-sage-100 bg-white p-7 shadow-soft transition-all duration-300 hover:-translate-y-1 hover:border-sage-200 hover:shadow-lift"
>
  <span class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-sage-50 text-sage-700 transition-colors group-hover:bg-sage-100">
    <Icon name={icon} size={28} />
  </span>
  <h3 class="mt-5 text-xl text-sage-900">{title}</h3>
  <p class="mt-3 flex-1 text-[1.05rem] leading-relaxed text-ink-soft">{summary}</p>
  <span class="mt-5 inline-flex items-center gap-2 font-semibold text-teal-700">
    Learn more
    <Icon name="arrow" size={18} class="transition-transform duration-300 group-hover:translate-x-1" />
  </span>
</a>
