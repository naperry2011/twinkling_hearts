---
import Icon from './Icon.astro';
import Sparkle from './Sparkle.astro';
interface Props {
  href: string;
  title: string;
  summary: string;
  /** Accepted for compatibility but no longer rendered (generic icons removed). */
  icon?: string;
}
const { href, title, summary } = Astro.props;
---
<a
  href={href}
  class="group flex h-full flex-col rounded-3xl border border-sage-100 bg-white p-7 shadow-soft transition-all duration-300 hover:-translate-y-1 hover:border-gold-300 hover:shadow-lift"
>
  <span class="flex items-center gap-2 text-gold-500">
    <Sparkle size={20} animate={false} />
    <span class="h-px flex-1 bg-gradient-to-r from-gold-300/70 to-transparent"></span>
  </span>
  <h3 class="mt-5 text-xl text-sage-900">{title}</h3>
  <p class="mt-3 flex-1 text-[1.05rem] leading-relaxed text-ink-soft">{summary}</p>
  <span class="mt-5 inline-flex items-center gap-2 font-semibold text-teal-700">
    Learn more
    <Icon name="arrow" size={18} class="transition-transform duration-300 group-hover:translate-x-1" />
  </span>
</a>
