---
interface Step {
  title: string;
  text: string;
}
interface Props {
  steps: Step[];
}
const { steps } = Astro.props;
---
<ol class="grid gap-6 md:grid-cols-3">
  {steps.map((step, i) => (
    <li class="relative rounded-3xl border border-sage-100 bg-white p-7 shadow-soft">
      <span class="flex h-12 w-12 items-center justify-center rounded-full bg-sage-700 font-display text-xl font-semibold text-cream">
        {i + 1}
      </span>
      <h3 class="mt-4 text-xl text-sage-900">{step.title}</h3>
      <p class="mt-2 text-[1.05rem] leading-relaxed text-ink-soft">{step.text}</p>
    </li>
  ))}
</ol>
