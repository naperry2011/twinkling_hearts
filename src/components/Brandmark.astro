---
/** Inline house + gold-heart + twinkle mark with wordmark. Matches brand on any bg. */
interface Props {
  class?: string;
  compact?: boolean;
}
const { class: className = '', compact = false } = Astro.props;
---
<span class:list={['inline-flex items-center gap-3', className]}>
  <svg width="44" height="44" viewBox="0 0 48 48" fill="none" aria-hidden="true" class="shrink-0">
    <!-- twinkle trail -->
    <g class="text-teal-400">
      <path d="M6 9l1 2 2 1-2 1-1 2-1-2-2-1 2-1 1-2Z" fill="currentColor" opacity="0.8"/>
      <circle cx="12.5" cy="13" r="1" fill="currentColor" opacity="0.5"/>
      <circle cx="16" cy="10.5" r="0.8" fill="#c9a24a" opacity="0.7"/>
    </g>
    <!-- house -->
    <path d="M24 7l14 11v1H10v-1L24 7Z" fill="#8aa67e"/>
    <path d="M12 19h24v18a1 1 0 0 1-1 1H13a1 1 0 0 1-1-1V19Z" fill="#a0b890"/>
    <!-- gold heart -->
    <path d="M24 36c-.3 0-.6-.1-.83-.32C20.4 33.1 17 30.2 17 26.7c0-2 1.5-3.5 3.4-3.5 1.2 0 2.3.6 3.1 1.6.8-1 1.9-1.6 3.1-1.6 1.9 0 3.4 1.5 3.4 3.5 0 3.5-3.4 6.4-6.17 8.98A1.2 1.2 0 0 1 24 36Z" fill="#d6b35f"/>
  </svg>
  {!compact && (
    <span class="leading-none">
      <span class="block font-display text-xl font-semibold tracking-tight text-sage-900">Twinkling Hearts</span>
      <span class="block text-xs font-semibold uppercase tracking-[0.22em] text-taupe-600">In Home Care</span>
    </span>
  )}
</span>
