---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Sparkle from './Sparkle.astro';
import LeafSprig from './LeafSprig.astro';

/**
 * Brand-treated photo: arched (house-roof) frame + gold hairline + unifying
 * duotone wash + optional sparkle/leaf accents. Harmonizes the stock photos
 * into one bespoke, on-brand look.
 */
interface Props {
  src: ImageMetadata;
  alt: string;
  widths?: number[];
  sizes?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'auto';
  shape?: 'arch' | 'rounded';
  sparkle?: boolean;
  leaf?: boolean;
  tilt?: 'left' | 'right' | 'none';
  class?: string;
}
const {
  src,
  alt,
  widths = [400, 612],
  sizes = '(min-width: 1024px) 28rem, 90vw',
  loading = 'lazy',
  fetchpriority = 'auto',
  shape = 'arch',
  sparkle = true,
  leaf = true,
  tilt = 'none',
  class: className = '',
} = Astro.props;

const radius = shape === 'arch' ? 'arch' : 'rounded-[1.75rem]';
const backTilt = tilt === 'left' ? '-rotate-2' : tilt === 'right' ? 'rotate-2' : '';
---
<div class:list={['relative mx-auto w-full', className]}>
  <!-- soft backing card echoing the frame -->
  <div
    aria-hidden="true"
    class:list={['absolute -inset-3 bg-sage-100/70', radius, backTilt]}
  ></div>

  <!-- framed photo with gold hairline + duotone wash -->
  <div class:list={['photo-wash relative shadow-lift ring-1 ring-gold-400/60', radius]}>
    <Image
      src={src}
      alt={alt}
      widths={widths}
      sizes={sizes}
      loading={loading}
      fetchpriority={fetchpriority}
      class="block h-full w-full object-cover"
    />
  </div>

  {sparkle && (
    <Sparkle size={46} trail class="pointer-events-none absolute -right-4 -top-5 text-gold-400/80" />
  )}
  {leaf && (
    <LeafSprig size={84} class="pointer-events-none absolute -bottom-5 -left-6 text-sage-500/80" />
  )}
</div>
