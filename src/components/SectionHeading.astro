---
import Sparkle from './Sparkle.astro';
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
  as?: 'h2' | 'h3';
  class?: string;
}
const { eyebrow, title, align = 'left', as: Tag = 'h2', class: className = '' } = Astro.props;
---
<div class:list={[align === 'center' ? 'text-center mx-auto max-w-2xl' : '', className]}>
  {eyebrow && (
    <span class:list={['eyebrow', align === 'center' && 'justify-center']}>
      <Sparkle size={16} animate={false} class="text-gold-500" />
      {eyebrow}
    </span>
  )}
  <Tag class="mt-3 text-3xl sm:text-4xl">{title}</Tag>
</div>
