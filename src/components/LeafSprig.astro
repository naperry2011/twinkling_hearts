---
/** Eucalyptus leaf sprig echoing the logo's botanicals. Decorative. */
interface Props {
  size?: number;
  class?: string;
  flip?: boolean;
}
const { size = 64, class: className = '', flip = false } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 80 60"
  width={size}
  height={size * 0.75}
  fill="currentColor"
  aria-hidden="true"
  class={className}
  style={flip ? 'transform: scaleX(-1)' : undefined}
>
  <!-- stem -->
  <path d="M4 54 C26 50 50 40 74 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
  <!-- leaves alternating along the stem -->
  <g opacity="0.9">
    <ellipse cx="20" cy="50" rx="9" ry="5" transform="rotate(-28 20 50)"/>
    <ellipse cx="34" cy="43" rx="9" ry="5" transform="rotate(-34 34 43)"/>
    <ellipse cx="47" cy="35" rx="8.5" ry="5" transform="rotate(-40 47 35)"/>
    <ellipse cx="58" cy="27" rx="8" ry="4.5" transform="rotate(-46 58 27)"/>
    <ellipse cx="67" cy="19" rx="7" ry="4" transform="rotate(-52 67 19)"/>
    <ellipse cx="28" cy="44" rx="7.5" ry="4.5" transform="rotate(18 28 44)"/>
    <ellipse cx="41" cy="36" rx="7" ry="4.5" transform="rotate(12 41 36)"/>
    <ellipse cx="53" cy="28" rx="6.5" ry="4" transform="rotate(6 53 28)"/>
  </g>
</svg>
