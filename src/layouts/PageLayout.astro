---
import BaseLayout from './BaseLayout.astro';
import Icon from '@/components/Icon.astro';
import { breadcrumbs as breadcrumbSchema } from '@/lib/schema';

interface Crumb {
  name: string;
  href: string;
}
interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  heading: string;
  intro?: string;
  /** Breadcrumb trail excluding Home (added automatically). */
  crumbs?: Crumb[];
  image?: string;
  jsonLd?: Record<string, unknown>[];
}
const {
  title,
  description,
  eyebrow,
  heading,
  intro,
  crumbs = [],
  image,
  jsonLd = [],
} = Astro.props;

const trail = [{ name: 'Home', href: '/' }, ...crumbs];
const structured = [breadcrumbSchema(trail), ...jsonLd];
---
<BaseLayout title={title} description={description} image={image} jsonLd={structured}>
  <section class="relative overflow-hidden border-b border-sage-100 bg-gradient-to-b from-sage-50 to-cream">
    <div aria-hidden="true" class="pointer-events-none absolute -right-10 top-6 opacity-50">
      <Icon name="leaf" size={140} class="text-sage-200" />
    </div>
    <div class="container-prose relative py-12 md:py-16">
      <nav aria-label="Breadcrumb" class="mb-5">
        <ol class="flex flex-wrap items-center gap-1.5 text-sm text-taupe-600">
          {trail.map((c, i) => (
            <li class="flex items-center gap-1.5">
              {i > 0 && <Icon name="arrow" size={14} class="text-sage-300" />}
              {i < trail.length - 1 ? (
                <a href={c.href} class="hover:text-teal-700">{c.name}</a>
              ) : (
                <span aria-current="page" class="font-semibold text-sage-800">{c.name}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>
      {eyebrow && (
        <span class="eyebrow"><Icon name="sparkle" size={15} class="text-gold-500" />{eyebrow}</span>
      )}
      <h1 class="mt-3 max-w-3xl text-4xl sm:text-5xl">{heading}</h1>
      {intro && <p class="mt-5 max-w-2xl text-xl leading-relaxed text-ink-soft">{intro}</p>}
    </div>
  </section>
  <slot />
</BaseLayout>
